{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: Run Chrome (Web)",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "chrome"],
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Launching.*",
          "endsPattern": "^.*Application running.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Flutter: Run macOS",
      "type": "shell",
      "command": "flutter",
      "args": ["run", "-d", "macos"],
