        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Launching.*",
          "endsPattern": "^.*Application running.*"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
